{
    "name": "fde-ai-work-items",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "next dev",
        "build": "next build",
        "start": "next start",
        "test": "vitest run",
        "e2e:smoke": "npm run db:reset && tsx tests/e2e-smoke.ts && npm run db:reset",
        "verify": "npm run lint && npm run test && npm run build && npm run e2e:smoke",
        "db:generate": "prisma generate",
        "db:push": "tsx prisma/prepare-db.ts && prisma db push --skip-generate",
        "db:seed": "prisma db seed",
        "db:reset": "tsx prisma/prepare-db.ts && prisma db push --force-reset --skip-generate && prisma db seed",
        "test:e2e": "playwright test",
        "test:e2e:ui": "playwright test --ui",
        "test:e2e:report": "playwright show-report",
        "test:e2e:auto": "pwsh e2e/run.ps1",
        "lint": "eslint .",
        "postinstall": "prisma generate",
        "lint:fix": "eslint --fix .",
        "format": "prettier --check .",
        "format:fix": "prettier --write ."
    },
    "dependencies": {
        "@prisma/client": "6.19.0",
        "@radix-ui/react-slot": "^1.2.4",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "lucide-react": "^0.561.0",
        "motion": "^12.40.0",
        "next": "16.2.6",
        "next-themes": "^0.4.6",
        "radix-ui": "^1.4.3",
        "react": "19.2.6",
        "react-dom": "19.2.6",
        "sonner": "^2.0.7",
        "tailwind-merge": "^3.4.0",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@eslint/eslintrc": "^3.3.3",
        "@faker-js/faker": "^10.4.0",
        "@playwright/mcp": "^0.0.75",
        "@playwright/test": "^1.60.0",
        "@tailwindcss/postcss": "4.3.0",
        "@types/node": "^22.19.1",
        "@types/react": "^19.2.7",
        "@types/react-dom": "^19.2.3",
        "eslint": "^9.39.4",
        "eslint-config-next": "^16.2.6",
        "eslint-config-prettier": "^10.1.8",
        "prettier": "^3.8.3",
        "prettier-plugin-tailwindcss": "^0.8.0",
        "prisma": "6.19.0",
        "tailwindcss": "4.3.0",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3",
        "vitest": "4.1.7"
    },
    "prisma": {
        "seed": "tsx prisma/seed.ts"
    }
}
